.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.sync {
  color: #7b8190;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.account-status {
  color: #476cff;
  font-size: 22rpx;
  margin-top: 8rpx;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.actions,
.nav,
.panel-actions,
.rank-buttons,
.form-actions,
.time-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.icon-button,
.circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #2f3542;
  background: #fff;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-size: 40rpx;
  line-height: 1;
}

.account-button {
  height: 64rpx;
  min-width: 88rpx;
  border: 2rpx solid #d7def2;
  border-radius: 32rpx;
  background: #fff;
  color: #34415f;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  font-size: 24rpx;
  line-height: 1;
}

.icon-button.soft {
  border: 0;
  background: #e0e5ff;
}

.controls {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.segment {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 2rpx solid #687083;
  border-radius: 36rpx;
  overflow: hidden;
  background: #fff;
}

.segment-button,
.today {
  width: 100%;
  height: 72rpx;
  border: 0;
  border-radius: 0;
  background: #fff;
  color: #111827;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
}

.segment-button::after,
.today::after,
.icon-button::after,
.account-button::after,
.circle::after,
.small-button::after,
.close::after,
.rank::after,
.text-button::after {
  border: 0;
}

.segment-button.active {
  background: #e2e6ff;
  color: #111827;
  font-weight: 700;
}

.today {
  width: 104rpx;
  border: 2rpx solid #687083;
  border-radius: 36rpx;
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  color: #8e929b;
  font-weight: 700;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 8rpx;
}

.calendar-scroll {
  width: 100%;
}

.calendar {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  background: #e9edf5;
  gap: 2rpx;
  border-top: 2rpx solid #e9edf5;
  border-left: 2rpx solid #e9edf5;
  width: 100%;
  box-sizing: border-box;
}

.day {
  min-width: 0;
  min-height: 184rpx;
  background: #fff;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.day.muted {
  color: #a6abb5;
}

.day.selected {
  background: #eef2ff;
}

.day-number {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.today-cell .day-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #4b73ff;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-preview-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.task-chip {
  height: 32rpx;
  border-radius: 6rpx;
  background: #8ba3f2;
  color: #21315b;
  display: flex;
  align-items: center;
  gap: 0;
  min-width: 0;
  padding: 0 8rpx;
  box-sizing: border-box;
  font-size: 21rpx;
  font-weight: 600;
}

.task-chip.spanning {
  background: #9aaff8;
}

.task-chip.done {
  opacity: 0.45;
}

.box,
.check {
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid #3d5b9d;
  border-radius: 4rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.chip-text {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  min-width: 0;
  width: 100%;
}

.more {
  color: #657084;
  font-size: 20rpx;
}

.week-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
}

.week-row {
  min-height: 120rpx;
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: stretch;
  background: #fff;
  border: 2rpx solid #e9edf5;
  border-radius: 12rpx;
  padding: 14rpx;
  box-sizing: border-box;
}

.selected-week-row {
  background: #eef2ff;
  border-color: #dbe4ff;
}

.today-week-row .week-date {
  background: #4b73ff;
  color: #fff;
}

.week-label {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  color: #111827;
}

.week-name {
  font-size: 28rpx;
  font-weight: 800;
}

.week-date {
  width: 70rpx;
  height: 42rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b8190;
  font-size: 22rpx;
  background: #f4f6fb;
}

.week-content {
  min-width: 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-content: center;
  gap: 8rpx;
}

.week-task-chip {
  min-width: 0;
  height: 42rpx;
  border-radius: 8rpx;
  background: #8ba3f2;
  color: #21315b;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 700;
}

.week-task-chip.spanning {
  background: #9aaff8;
}

.week-task-chip.done {
  opacity: 0.45;
}

.week-empty {
  grid-column: 1 / -1;
  color: #a6abb5;
  font-size: 24rpx;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(17, 24, 39, 0.22);
  z-index: 20;
}

.day-panel,
.form-panel,
.account-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 20rpx 60rpx rgba(31, 41, 55, 0.18);
  z-index: 30;
  max-height: 78vh;
  overflow: hidden;
}

.panel-header {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #edf0f5;
  box-sizing: border-box;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 800;
}

.panel-subtitle,
.detail-meta,
.description {
  color: #7b8190;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.small-button,
.close,
.rank,
.text-button {
  border: 0;
  background: transparent;
  padding: 0 8rpx;
  color: #476cff;
  font-size: 26rpx;
}

.muted-button {
  color: #6b7280;
}

.close {
  color: #111827;
  font-size: 42rpx;
}

.task-list {
  max-height: 58vh;
  padding: 18rpx 28rpx 32rpx;
  box-sizing: border-box;
}

.section-title {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 700;
  margin: 18rpx 0 10rpx;
}

.detail-task {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f2f7;
}

.spanning-row {
  background: #f7f9ff;
  border-radius: 8rpx;
  padding: 18rpx;
  border-bottom: 0;
  margin-bottom: 10rpx;
}

.check {
  width: 32rpx;
  height: 32rpx;
  margin-top: 4rpx;
  color: #476cff;
  font-weight: 800;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 700;
  word-break: break-all;
}

.done-text {
  color: #9ca3af;
  text-decoration: line-through;
}

.rank {
  width: 40rpx;
  height: 40rpx;
  color: #34415f;
}

.sort-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 8rpx;
  background: #fff;
  overflow: hidden;
}

.sort-item {
  width: 100%;
  height: 108rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8faff;
  border: 2rpx solid #e5ebff;
  box-sizing: border-box;
  color: #111827;
}

.sort-item.dragging {
  background: #eef2ff;
  border-color: #b8c7ff;
  transform: scale(0.99);
}

.drag-handle {
  width: 40rpx;
  color: #7b8190;
  font-size: 34rpx;
  line-height: 1;
}

.danger {
  color: #d64545;
}

.empty {
  color: #9ca3af;
  padding: 30rpx 0;
  text-align: center;
}

.form {
  padding: 26rpx 28rpx;
}

.account-password {
  margin-top: 18rpx;
}

.account-help {
  color: #7b8190;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 18rpx;
}

.input,
.textarea,
.picker {
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.title-input {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.textarea {
  height: 148rpx;
  width: 100%;
  padding-top: 18rpx;
  margin-bottom: 18rpx;
}

.form-row {
  min-height: 86rpx;
  display: grid;
  grid-template-columns: 120rpx 1fr;
  align-items: center;
  gap: 18rpx;
  font-size: 28rpx;
}

.time-row {
  margin: 6rpx 0 12rpx 138rpx;
}

.time-row picker {
  flex: 1;
}

.form-actions {
  padding: 20rpx 28rpx 28rpx;
}

.secondary,
.primary {
  flex: 1;
  height: 84rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: 1;
  box-sizing: border-box;
}

.secondary {
  color: #6b7280;
  background: #fff;
  border: 2rpx solid #e5e7eb;
}

.primary {
  color: #fff;
  background: #476cff;
  border: 0;
}
